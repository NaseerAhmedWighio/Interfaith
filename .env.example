# ============================================================
# Database
# ============================================================
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/interfaith_db?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=interfaith_db
DB_PORT=5432

# ============================================================
# Docker
# ============================================================
DOCKERHUB_USERNAME=your_dockerhub_username
APP_PORT=3060

# ============================================================
# Authentication
# ============================================================
SESSION_SECRET="your_random_64_character_hex_string"

# ============================================================
# Email Service (Resend)
# Sign up at https://resend.com to get your API key
# ============================================================
RESEND_API_KEY="re_your_api_key_here"
FROM_EMAIL="noreply@yourdomain.com"

# ============================================================
# App URLs
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3060"
NEXT_PUBLIC_API_URL="http://localhost:3060/api"

# ============================================================
# Admin Seed Account (created by prisma db seed)
# ============================================================
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="your_strong_admin_password"
ADMIN_NAME="Super Admin"

# ============================================================
# Moderator Seed Account (created by prisma db seed)
# ============================================================
MODERATOR_EMAIL="moderator@yourdomain.com"
MODERATOR_PASSWORD="your_strong_moderator_password"
MODERATOR_NAME="Head Moderator"

# ============================================================
# Google Services (SEO, Analytics)
# ============================================================
NEXT_PUBLIC_GOOGLE_VERIFICATION=""
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_GTM_ID=""

# ============================================================
# Node Environment
# ============================================================
NODE_ENV="production"
