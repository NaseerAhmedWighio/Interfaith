# Database Configuration
# Replace with your local PostgreSQL credentials
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/interfaith_db?schema=public"

# Authentication
SESSION_SECRET="your_session_secret_here_generate_a_random_string"

# Email Service (Resend)
# Sign up at https://resend.com to get your API key
# Required for email verification and password reset functionality
RESEND_API_KEY="re_your_api_key_here"
FROM_EMAIL="noreply@yourdomain.com"

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Admin Seed Account (created by prisma seed)
ADMIN_EMAIL="admin@interfaithpeacebridge.org"
ADMIN_NAME="Super Admin"
# Generate a strong password:
ADMIN_PASSWORD="your_strong_admin_password"

# Moderator Seed Account (created by prisma seed)
MODERATOR_EMAIL="moderator@interfaithpeacebridge.org"
MODERATOR_NAME="Head Moderator"
MODERATOR_PASSWORD="your_strong_moderator_password"

# Google Services (SEO, Analytics, Search Console)
# Get verification code from Google Search Console > Settings > Ownership verification
NEXT_PUBLIC_GOOGLE_VERIFICATION=""
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
# Google Tag Manager Container ID (format: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=""

# Node Environment
NODE_ENV="development"

# Remove these Supabase variables (no longer needed)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
